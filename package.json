{
  "name": "plugin-updater",
  "version": "1.5.0",
  "description": "Plugin lifecycle manager for OpenCode and Claude Code launchers",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "plugin-updater": "dist/cli.js"
  },
  "license": "MIT",
  "author": "intisy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intisy-ai/plugin-updater.git"
  },
  "keywords": [
    "opencode",
    "claude",
    "plugin",
    "updater",
    "lifecycle"
  ],
  "files": [
    "dist/",
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npx esbuild core/src/index.ts --bundle --platform=node --format=esm --outfile=lib/core.js && tsc",
    "test": "npm run build && vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.6"
  }
}
